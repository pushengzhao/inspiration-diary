page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
}

.container {
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  color: white;
}

.date-info {
  flex: 1;
}

.date-info .date {
  font-size: 36rpx;
  font-weight: bold;
}

.date-info .weekday {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

.weather {
  text-align: right;
}

.stats {
  display: flex;
  justify-content: space-around;
  background: white;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #667eea;
}

.entry-list {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.entry-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.entry-item:last-child {
  border-bottom: none;
}

.entry-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.entry-icon.inspiration {
  background: #fff3e0;
  color: #ff9800;
}

.entry-icon.event {
  background: #e3f2fd;
  color: #2196f3;
}

.entry-icon.thought {
  background: #f3e5f5;
  color: #9c27b0;
}

.entry-content {
  flex: 1;
}

.entry-type {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.entry-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.entry-time {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 10rpx;
}

.generate-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  z-index: 100;
}

.generate-btn .icon {
  font-size: 48rpx;
}

.generate-btn .text {
  font-size: 20rpx;
  margin-top: 5rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-state .text {
  font-size: 28rpx;
  line-height: 1.8;
}
