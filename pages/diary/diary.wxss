.diary-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  color: white;
  text-align: center;
  margin-bottom: 40rpx;
}

.date {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.weekday {
  font-size: 32rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.weather {
  font-size: 28rpx;
  opacity: 0.8;
}

.diary-content {
  padding: 0 30rpx;
}

.diary-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 40rpx;
}

.diary-text {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section:last-of-type {
  border-bottom: none;
}

.section-icon {
  font-size: 48rpx;
  margin-right: 25rpx;
  flex-shrink: 0;
}

.section-content {
  flex: 1;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.section-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-indent: 2em;
}

.summary {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 30rpx;
  border-radius: 15rpx;
  margin-top: 30rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-indent: 2em;
}

.action-buttons {
  display: flex;
  justify-content: space-around;
  margin-top: 50rpx;
  padding: 30rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  border-radius: 15rpx;
  transition: all 0.3s;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.copy-btn {
  background: #e3f2fd;
  color: #2196f3;
}

.share-btn {
  background: #fff3e0;
  color: #ff9800;
}

.save-btn {
  background: #f3e5f5;
  color: #9c27b0;
}

.generating-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.loading-animation {
  display: flex;
  gap: 15rpx;
  margin-bottom: 40rpx;
}

.loading-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.loading-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.loading-tip {
  font-size: 26rpx;
  color: #999;
}
