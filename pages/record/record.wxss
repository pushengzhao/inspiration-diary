.form-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.type-selector {
  display: flex;
  justify-content: space-around;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 40rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.type-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  transform: scale(1.05);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 15rpx;
}

.type-name {
  font-size: 26rpx;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 15rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.tag-input-container {
  margin-bottom: 20rpx;
}

.tag-input {
  width: 100%;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 15rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #e3f2fd;
  color: #2196f3;
  border-radius: 25rpx;
  font-size: 24rpx;
}

.tag-remove {
  margin-left: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  text-align: center;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.preview-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.preview-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.preview-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.preview-item:last-child {
  border-bottom: none;
}

.preview-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 28rpx;
}

.preview-icon.inspiration {
  background: #fff3e0;
}

.preview-icon.event {
  background: #e3f2fd;
}

.preview-icon.thought {
  background: #f3e5f5;
}

.preview-content {
  flex: 1;
}

.preview-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.preview-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}
