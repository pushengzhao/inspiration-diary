<view class="container">
  <!-- 头部日期信息 -->
  <view class="header">
    <view class="date-info">
      <view class="date">{{currentDate}}</view>
      <view class="weekday">{{weekday}}</view>
    </view>
    <view class="weather">
      <text>🌤️</text>
      <text>25°C</text>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats">
    <view class="stat-item">
      <view class="stat-number">{{inspirationCount}}</view>
      <view class="stat-label">灵感</view>
    </view>
    <view class="stat-item">
      <view class="stat-number">{{eventCount}}</view>
      <view class="stat-label">事件</view>
    </view>
    <view class="stat-item">
      <view class="stat-number">{{thoughtCount}}</view>
      <view class="stat-label">感悟</view>
    </view>
    <view class="stat-item">
      <view class="stat-number">{{totalCount}}</view>
      <view class="stat-label">总计</view>
    </view>
  </view>

  <!-- 今日灵感 -->
  <view class="section-title">今日灵感</view>
  <view class="entry-list" wx:if="{{inspirations.length > 0}}">
    <view class="entry-item" wx:for="{{inspirations}}" wx:key="id">
      <view class="entry-icon inspiration">💡</view>
      <view class="entry-content">
        <view class="entry-type">灵感 · {{item.time}}</view>
        <view class="entry-text">{{item.content}}</view>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:else>
    <view class="icon">💡</view>
    <view class="text">还没有记录灵感\n点击下方按钮快速记录</view>
  </view>

  <!-- 今日事件 -->
  <view class="section-title">今日事件</view>
  <view class="entry-list" wx:if="{{events.length > 0}}">
    <view class="entry-item" wx:for="{{events}}" wx:key="id">
      <view class="entry-icon event">📅</view>
      <view class="entry-content">
        <view class="entry-type">事件 · {{item.time}}</view>
        <view class="entry-text">{{item.content}}</view>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:else>
    <view class="icon">📅</view>
    <view class="text">还没有记录事件\n去记录今天发生的事吧</view>
  </view>

  <!-- 读书感悟 -->
  <view class="section-title">读书感悟</view>
  <view class="entry-list" wx:if="{{thoughts.length > 0}}">
    <view class="entry-item" wx:for="{{thoughts}}" wx:key="id">
      <view class="entry-icon thought">📖</view>
      <view class="entry-content">
        <view class="entry-type">感悟 · {{item.time}}</view>
        <view class="entry-text">{{item.content}}</view>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:else>
    <view class="icon">📖</view>
    <view class="text">还没有读书感悟\n记录你的思考与收获</view>
  </view>

  <!-- 生成日记按钮 -->
  <view class="generate-btn" bindtap="generateDiary">
    <view class="icon">✨</view>
    <view class="text">生成日记</view>
  </view>
</view>
